# Copy to .env in the project root and fill in values.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: override default model (gpt-4o-mini is used if unset)
# OPENAI_MODEL=gpt-4o-mini

# Frontend: Vite reads VITE_* at build time (optional; defaults work for local dev)
# VITE_API_URL=http://127.0.0.1:8000
